# Server runtime
PORT=3000
NODE_ENV=development
# Log verbosity for the structured JSON server logs: debug | info | warn | error
LOG_LEVEL=info

# Firebase (client, web) configuration — from Firebase Console > Project Settings.
# NOT secret — this ships inside the client bundle by design; Firebase access
# control is enforced by firestore.rules + Google OAuth, not by hiding this.
# Kept in env so different environments can point at different Firebase projects.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:0000000000000000000000"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"
VITE_FIREBASE_FIRESTORE_DATABASE_ID="(default)"

# Comma-separated allowlist of emails exempt from the 3-generation free quota
# (e.g. your own testing account). Leave empty in production if not needed.
VITE_TEST_ACCOUNT_EMAILS="rafirasheed.tc99@gmail.com"

# Comma-separated allowlist of emails allowed to view /admin (the KPI dashboard
# at GET /api/admin/dashboard). Server-side only — never exposed to the client.
ADMIN_EMAILS="you@example.com"

# Firebase Admin (server-side): REQUIRED for verifying user sessions and
# enforcing the generation quota server-side — without this, /api/analyze-pet
# and /api/generate-pet-image reject every request. Must match VITE_FIREBASE_PROJECT_ID.
FIREBASE_PROJECT_ID="your-project"
# Optional dedicated service account for the Firebase project (needed for
# Firestore admin reads/writes — quota enforcement). Without it, the server
# falls back to GOOGLE_APPLICATION_CREDENTIALS below, which only works for
# Firestore if that service account has IAM access on the Firebase project —
# if your Vertex AI project and Firebase project are different GCP projects
# (common when this was scaffolded from AI Studio), either:
#   (a) grant the Vertex service account's email "Cloud Datastore User" IAM
#       role on the Firebase project in Google Cloud Console > IAM, or
#   (b) generate a dedicated key: Firebase Console > Project Settings >
#       Service Accounts > Generate new private key, and set this path.
# FIREBASE_SERVICE_ACCOUNT_PATH="/absolute/path/to/firebase-service-account.json"

# Google Cloud / Vertex AI configuration
# This app uses Google Cloud project credentials instead of the AI Studio API-key flow.
# Set GCP_PROJECT_ID and ensure Google Application Default Credentials are available.
GCP_PROJECT_ID="YOUR_GCP_PROJECT_ID"
GCP_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# Optional Gemini model overrides
# Analysis also does the human/pet safety gate, so it needs real multimodal
# judgment, not just cheap text extraction — flash-lite let human photos through.
# Keep this at flash or higher; image generation is the actual expensive step.
GEMINI_ANALYZE_MODEL="gemini-2.5-flash"
GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"

# Rough cost estimates per 1M tokens, used ONLY for the server's cost logging.
# Defaults are approximate USD list prices as of early 2026 — override to match
# your actual model + billing plan. Image OUTPUT is by far the dominant cost.
GEMINI_ANALYZE_INPUT_COST_PER_1M_TOKENS=0.10
GEMINI_ANALYZE_OUTPUT_COST_PER_1M_TOKENS=0.40
GEMINI_IMAGE_INPUT_COST_PER_1M_TOKENS=0.30
GEMINI_IMAGE_OUTPUT_COST_PER_1M_TOKENS=30.0

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CREATOR_EMAIL: Destination email for quota upgrade notifications. Required —
# the server refuses to start without it (no hardcoded fallback recipient).
CREATOR_EMAIL="you@example.com"

# SMTP Configuration (Optional but recommended for full-stack email triggers - e.g., Gmail with App Password or Resend/Amazon SES SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Google Analytics (Optional ID - e.g., G-XXXXXXXXXX)
# Used to track visitor statistics and custom Gemini token usage alerts.
VITE_GA_MEASUREMENT_ID=

